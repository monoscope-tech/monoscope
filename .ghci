:set prompt "\ESC[1;32m\x03BB> \ESC[m"
:set prompt-cont "\ESC[1;32m > \ESC[m"
:seti -XGADTSyntax
:seti -XGeneralizedNewtypeDeriving
:seti -XInstanceSigs
:seti -XLambdaCase
:seti -XPartialTypeSignatures
:seti -XScopedTypeVariables
:seti -XTypeApplications
:seti -XOverloadedStrings
:seti -XImportQualifiedPost

:set -Wno-prepositive-qualified-module


:set +m
:set +s
:set +t

-- :set -package pretty-simple

:set -fprint-explicit-foralls
-- :set -interactive-print=Text.Pretty.Simple.pPrint
:set -XTypeApplications -XKindSignatures

-- Keep unused-bind/import warnings visible in the dev loop, but non-fatal:
-- the package ghc-options run with -Werror, and re-enabling these here (after
-- the cabal -Wno-unused-imports) otherwise makes every unused import across the
-- codebase a fatal load error, breaking `make live-test-dev` entirely.
:set -Wunused-binds -Wunused-imports -Wwarn=unused-binds -Wwarn=unused-imports

-- :set -optl-Wl,-rpath,/Users/tonyalaribe/Projects/apitoolkit/apitoolkit-server/.stack-work/dist/aarch64-osx/ghc-9.8.3/build/

-- :load Main
